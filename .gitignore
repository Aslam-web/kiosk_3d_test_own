# Node / build tooling
node_modules/
.vendor-tmp/
# Generated by `npm run fetch` (~44 MB Three.js + MediaPipe)
src/vendor/
# Leftover Vite cache from the old _archive/ codebase
.vite/
.cache/
dist/
build/
*.tsbuildinfo
.eslintcache
coverage/

# Tauri / Rust build output
src-tauri/target/
src-tauri/gen/
# Tauri downloads WiX here on first MSI build
src-tauri/WixTools/

# Environment / secrets
.env
.env.local
.env.*.local
# mkcert-generated LAN HTTPS certs (regenerate with `mkcert` on each machine)
cert.pem
key.pem
*.pem

# Editor / IDE
.idea/
.vscode/

# OS cruft
.DS_Store
Thumbs.db
ehthumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Bulky reference assets kept out of the repo
/linkedin-video.mp4
# Abandoned Vite/TS codebase — kept locally for reference, not pushed
/_archive/
# Source archives in src/assets/ — the unpacked folders next to them
# (e.g. pickups/, livingroom.rwi/) are what the app actually loads
src/assets/*.zip
