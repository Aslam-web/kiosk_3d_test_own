{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FishtankVR",
  "version": "0.1.0",
  "identifier": "com.aslam.fishtankvr",

  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "npm run serve",
    "beforeBuildCommand": ""
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FishtankVR",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "focus": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' data: blob:; worker-src 'self' blob:; font-src 'self' data:"
    }
  },

  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "© 2026 Aslam",
    "category": "Utility",
    "shortDescription": "Head-tracked 3D kiosk",
    "longDescription": "Move your head to peek into a virtual 3D scene through the screen. Uses the webcam plus on-device face tracking — no cloud, works offline."
  }
}
